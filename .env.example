# MCP Guardian — Environment Variables
# Copy this file to .env and fill in values as needed.

# NVD API key (optional, for NVD CVE lookups)
# Get a free key at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# OpenAI API key (for tiktoken token counting — not strictly required if using local models)
OPENAI_API_KEY=

# Database path (defaults to ~/.mcp-guardian/history.db)
MCP_GUARDIAN_DB_PATH=

# Custom pricing overrides (USD per 1M tokens)
# Example: PRICING_OVERRIDES='{"my-model": {"input": 2.0, "output": 6.0}}'
PRICING_OVERRIDES=

# Log level: DEBUG, INFO, WARN, ERROR (default: INFO)
LOG_LEVEL=INFO

# ── Dashboard & live TUI ─────────────────────────────────────
# Enable the dashboard REST API (HTML at / always lists API + TUI docs)
DASHBOARD_ENABLED=true
# WebSocket push for TUI (default true when proxy starts)
GUARDIAN_WS_ENABLED=true
GUARDIAN_WS_PUSH_INTERVAL_MS=5000
# Dashboard server port (default: 4000)
DASHBOARD_PORT=4000
# TUI: merge metrics from dashboard (optional)
GUARDIAN_DASHBOARD_URL=http://127.0.0.1:4000

# ── AI learning (enabled by default; set GUARDIAN_AI_ENABLED=false to disable) ──
GUARDIAN_AI_ENABLED=true
GUARDIAN_AI_AUTO_APPLY=false
GUARDIAN_AI_USE_DB_SNAPSHOTS=true
# GUARDIAN_AI_DISABLE_THREAT_POLL=false
# GUARDIAN_AI_THREAT_POLL_MS=1800000
# GUARDIAN_SWARM_USE_LEGACY_ARTIFACTS=false
# GUARDIAN_UPSTREAM_TIMEOUT_MS=30000
# GUARDIAN_REGEX_EVAL_TIMEOUT_MS=50
# GUARDIAN_SEMANTIC_LLM_MAX_PER_MIN=10
# GUARDIAN_SEMANTIC_CIRCUIT_THRESHOLD=5
# GUARDIAN_SEMANTIC_CIRCUIT_RESET_MS=60000
# GUARDIAN_TENANT_AUDIT_PATHS=true
# GUARDIAN_PG_RLS_ENABLED=false
# GUARDIAN_OPEN_CORE=true  # deprecated in v3.0 — Pro gates always apply
# GUARDIAN_DEV_UNLOCK_ALL=true  # with NODE_ENV=development only (maintainers)
# GUARDIAN_CI_BYPASS_LICENSE=true  # CI workflows only — not for production
# GUARDIAN_PRO_CHECKOUT_URL=https://mcp-guardian.lemonsqueezy.com/checkout/buy/f725abfe-93c0-4bd7-8add-d15af13958fb
# GUARDIAN_LICENSE_KEY=
# GUARDIAN_CONTROL_PLANE_URL=https://your-cloud.vercel.app
# GUARDIAN_COST_BUDGET_USD=150
GUARDIAN_AI_MIN_BASELINE_SAMPLES=3
GUARDIAN_TUI_SKIP_LEARNING=false
GUARDIAN_AI_SKIP_INITIAL_CYCLE=false
# Run AI learning on scan/audit/health/report (default: proxy/TUI only)
GUARDIAN_AI_ON_CLI=false
GUARDIAN_SKIP_PREFLIGHT_SCAN=false
# Opt-in: block tools/call when upstream scan has CVEs at/above threshold (default CRITICAL)
GUARDIAN_BLOCK_ON_CVE=false
# GUARDIAN_CVE_BLOCK_SEVERITY=CRITICAL

# ── Dashboard Authentication ───────────────────────────────────
# Auth on by default when dashboard is enabled. Local dev only:
# DASHBOARD_AUTH_DISABLED=true
DASHBOARD_AUTH_ENABLED=true
# API Key for simple authentication (use /?api_key=<key> or Authorization: Bearer <key>)
DASHBOARD_API_KEY=
# JWT HMAC secret for session-based authentication (generate: openssl rand -hex 32)
DASHBOARD_JWT_SECRET=
# Credentials for username/password login (requires DASHBOARD_JWT_SECRET)
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=
# Comma-separated allowed origins for CSRF validation
DASHBOARD_ALLOWED_ORIGINS=http://localhost:4000,http://localhost:3000,http://127.0.0.1:4000
# Allow public access to /metrics without authentication
DASHBOARD_METRICS_PUBLIC=false

# ── Metrics ────────────────────────────────────────────────────
METRICS_ENABLED=true
METRICS_PORT=9090
# Redis URL for distributed session/rate-limit store
REDIS_URL=

# ── Policy Audit ───────────────────────────────────────────────
# Enable policy change audit logging (JSONL format)
POLICY_AUDIT_ENABLED=true
POLICY_AUDIT_LOG=./policy-audit.jsonl

# ── Payload Normalization (v1.2+) ──────────────────────────────
# Max decode depth for URL/hex/entity normalization (default: 5)
NORMALIZER_MAX_DEPTH=5
# Max input size for normalization in bytes (default: 1000000)
NORMALIZER_MAX_LENGTH=1000000