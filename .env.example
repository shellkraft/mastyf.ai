# MCP Mastyff AI — Environment Variables
# Copy this file to .env and fill in values as needed.

# NVD API key (optional, for NVD CVE lookups)
# Get a free key at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# OpenAI API key (for tiktoken token counting — not strictly required if using local models)
OPENAI_API_KEY=

# Database path (defaults to ~/.mastyff-ai/history.db)
MASTYFF_AI_DB_PATH=
# Audit retention (days, default 30; SOX/PCI often 90–365)
# MASTYFF_AI_RETENTION_DAYS=30
# Field encryption at rest (requires MASTYFF_AI_DB_ENCRYPTION_KEY)
# MASTYFF_AI_DB_ENCRYPTION_KEY=
# MASTYFF_AI_DB_ENCRYPT_AUDIT_ARGS=true
# JWKS refresh for OAuth JWT validation (default 5 minutes)
# MASTYFF_AI_JWKS_REFRESH_MS=300000
# Payload limits (bytes)
# MASTYFF_AI_MAX_PAYLOAD_BYTES=10485760
# MASTYFF_AI_MAX_EXPANDED_PAYLOAD_BYTES=52428800
# MASTYFF_AI_STRICT_ALLOWLIST_RBAC=true
# MASTYFF_AI_HEALTH_PROBE_INTERVAL_MS=0
# MASTYFF_AI_SHUTDOWN_GRACE_MS=30000
# SIEM exporters (splunk, datadog, webhook, etc.)
# MASTYFF_AI_SIEM_ENABLED=true
# MASTYFF_AI_SIEM_EXPORTERS=splunk,webhook
# MASTYFF_AI_SIEM_SPLUNK_HEC_URL=
# MASTYFF_AI_SIEM_SPLUNK_HEC_TOKEN=

# Custom pricing overrides (USD per 1M tokens)
# Example: PRICING_OVERRIDES='{"my-model": {"input": 2.0, "output": 6.0}}'
PRICING_OVERRIDES=

# Log level: DEBUG, INFO, WARN, ERROR (default: INFO)
LOG_LEVEL=INFO

# ── Dashboard & live TUI ─────────────────────────────────────
# Enable the dashboard REST API (HTML at / always lists API + TUI docs)
DASHBOARD_ENABLED=true
# WebSocket push for TUI (default true when proxy starts)
MASTYFF_AI_WS_ENABLED=true
MASTYFF_AI_WS_PUSH_INTERVAL_MS=5000
# Dashboard server port (default: 4000)
DASHBOARD_PORT=4000
# TUI: merge metrics from dashboard (optional)
MASTYFF_AI_DASHBOARD_URL=http://127.0.0.1:4000

# ── AI learning (enabled by default; set MASTYFF_AI_AI_ENABLED=false to disable) ──
MASTYFF_AI_AI_ENABLED=true
MASTYFF_AI_AI_AUTO_APPLY=false
MASTYFF_AI_AI_USE_DB_SNAPSHOTS=true
# MASTYFF_AI_AI_DISABLE_THREAT_POLL=false
# MASTYFF_AI_AI_THREAT_POLL_MS=1800000
# MASTYFF_AI_SWARM_USE_LEGACY_ARTIFACTS=false
# MASTYFF_AI_DASHBOARD_STRICT_LIVE=true  # default: hide stale/committed swarm artifacts until a job runs this session
# Mastyff AI Autopilot (or: mastyff-ai autopilot init && autopilot start)
# MASTYFF_AI_AUTOPILOT=true
# MASTYFF_AI_THREAT_RESEARCH_AUTO=true
# MASTYFF_AI_THREAT_DISCOVERY_AUTOSTART=true
# MASTYFF_AI_REPORT_SCHEDULE=daily
# MASTYFF_AI_REPORT_CRON_HOUR=6
# MASTYFF_AI_AUTOPILOT_CORPUS_GATE=true
# MASTYFF_AI_LLM_ENABLED=true
# MASTYFF_AI_LLM_MODEL=qwen3:8b
# OLLAMA_BASE_URL=http://localhost:11434
# MASTYFF_AI_SEMANTIC_ASYNC=true  # on by default when LLM enabled; post-hoc semantic audit (Pro)
# MASTYFF_AI_UPSTREAM_TIMEOUT_MS=30000
# MASTYFF_AI_REGEX_EVAL_TIMEOUT_MS=50
# MASTYFF_AI_REGEX_USE_WORKER=true  # worker-thread regex eval (default on in production)
# MASTYFF_AI_POLICY_REJECT_UNSAFE_REGEX=true  # fail policy load on ReDoS-risk patterns (default true in production)
# MASTYFF_AI_SEMANTIC_LLM_TIMEOUT_MS=30000  # alias for MASTYFF_AI_LLM_TIMEOUT_MS in @mastyff-ai/core
# MASTYFF_AI_SEMANTIC_LLM_MAX_PER_MIN=10
# MASTYFF_AI_SEMANTIC_LLM_MAX_USD_PER_MIN=0.03  # optional; default = max_per_min × estimated cost
# MASTYFF_AI_SEMANTIC_CIRCUIT_THRESHOLD=5
# MASTYFF_AI_SEMANTIC_CIRCUIT_RESET_MS=60000
# MASTYFF_AI_TENANT_AUDIT_PATHS=true
# MASTYFF_AI_PG_RLS_ENABLED=false
# MASTYFF_AI_OPEN_CORE=true  # deprecated in v3.0 — Pro gates always apply
# MASTYFF_AI_DEV_UNLOCK_ALL=true  # with NODE_ENV=development only (maintainers)
# MASTYFF_AI_CI_BYPASS_LICENSE=true  # CI workflows only — not for production
# MASTYFF_AI_PRO_CHECKOUT_URL=https://mastyff-ai.lemonsqueezy.com/checkout/buy/f725abfe-93c0-4bd7-8add-d15af13958fb
# MASTYFF_AI_LICENSE_KEY=
# MASTYFF_AI_CONTROL_PLANE_URL=https://your-cloud.vercel.app
# MASTYFF_AI_JWT_MAX_LIFETIME_SEC=86400
# MASTYFF_AI_JWT_STRICT_LIFETIME=false  # fail startup when max lifetime > 86400
# MASTYFF_AI_SEMANTIC_SYNC_RESPONSE=false  # production defaults ON unless explicitly false
# SWARM_ALERT_WEBHOOK_URL=  # security swarm failure webhook (falls back to ALERT_WEBHOOK_URL)
# SWARM_ARCHIVE_RETENTION_DAYS=30
MASTYFF_AI_AI_MIN_BASELINE_SAMPLES=3
MASTYFF_AI_TUI_SKIP_LEARNING=false
MASTYFF_AI_AI_SKIP_INITIAL_CYCLE=false
# Run AI learning on scan/audit/health/report (default: proxy/TUI only)
MASTYFF_AI_AI_ON_CLI=false
MASTYFF_AI_SKIP_PREFLIGHT_SCAN=false
# Opt-in: block tools/call when upstream scan has CVEs at/above threshold (default CRITICAL)
MASTYFF_AI_BLOCK_ON_CVE=false
# MASTYFF_AI_CVE_BLOCK_SEVERITY=CRITICAL

# ── Industry-standard roadmap (A1–C5, B1–B3) ─────────────────
# Cross-MCP fleet chain blocking (default confidence 0.65)
# MASTYFF_AI_FLEET_CHAIN_BLOCK_CONFIDENCE=0.65
# MASTYFF_AI_FLEET_CHAIN_REDIS=true
# MASTYFF_AI_FLEET_REGION=us-east-1
# MASTYFF_AI_FLEET_PEER_REGIONS=eu-west-1,ap-southeast-1
# Optional ONNX graph classifier for fleet chain scoring (A1)
# MASTYFF_AI_FLEET_GRAPH_ONNX_MODEL=/path/to/graph-model.onnx
# MASTYFF_AI_FLEET_GRAPH_ONNX=false
# Ecosystem observatory cloud relay (B2); use stub for local dev without relay
# MASTYFF_AI_OBSERVATORY_RELAY_URL=https://your-cloud.example/api/v1
# MASTYFF_AI_OBSERVATORY_RELAY_API_KEY=
# MASTYFF_AI_OBSERVATORY_STUB=true
# Federated threat learning (B3)
# MASTYFF_AI_FEDERATED_LEARNING=true
# MASTYFF_AI_FEDERATED_ONNX_MODEL=/path/to/model.onnx
# MASTYFF_AI_FEDERATED_MPC=true
# MASTYFF_AI_FEDERATED_MPC_SECRET=
# Behavioral biometrics warmup before enforcement (A3)
# MASTYFF_AI_BIOMETRICS_MIN_SAMPLES=10
# Zero-trust geo allowlist (C3)
# MASTYFF_AI_ZERO_TRUST_ALLOWED_REGIONS=US,CA,GB
# SPIFFE workload identity socket (C3)
# MASTYFF_AI_SPIFFE_SOCKET_PATH=/run/spire/sockets/agent.sock

# ── Dashboard Authentication ───────────────────────────────────
# Auth on by default when dashboard is enabled. Local dev only:
# DASHBOARD_AUTH_DISABLED=true
DASHBOARD_AUTH_ENABLED=true
# API Key for simple authentication (use /?api_key=<key> or Authorization: Bearer <key>)
DASHBOARD_API_KEY=
# JWT HMAC secret for session-based authentication (generate: openssl rand -hex 32)
DASHBOARD_JWT_SECRET=
# Credentials for username/password login (requires DASHBOARD_JWT_SECRET)
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=
# Comma-separated allowed origins for CSRF validation
DASHBOARD_ALLOWED_ORIGINS=http://localhost:4000,http://localhost:3000,http://127.0.0.1:4000
# Allow public access to /metrics without authentication
DASHBOARD_METRICS_PUBLIC=false

# ── Metrics ────────────────────────────────────────────────────
METRICS_ENABLED=true
METRICS_PORT=9090
# Redis URL for distributed session/rate-limit store
REDIS_URL=

# ── Policy Audit ───────────────────────────────────────────────
# Enable policy change audit logging (JSONL format)
POLICY_AUDIT_ENABLED=true
POLICY_AUDIT_LOG=./policy-audit.jsonl

# ── Payload Normalization (v1.2+) ──────────────────────────────
# Max decode depth for URL/hex/entity normalization (default: 5)
NORMALIZER_MAX_DEPTH=5
# Max input size for normalization in bytes (default: 1000000)
NORMALIZER_MAX_LENGTH=1000000