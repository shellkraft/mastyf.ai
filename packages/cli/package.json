{
  "name": "@mastyf-ai/cli",
  "version": "4.1.7",
  "description": "CLI binary for scanning MCP tool definitions",
  "type": "module",
  "bin": {
    "mastyf-ai": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "pnpm --dir ../server run build && tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepack": "node ../../scripts/prepack-npm-deps.mjs",
    "prepublishOnly": "pnpm run build && node ../../scripts/validate-npm-pack.mjs"
  },
  "dependencies": {
    "@mastyf-ai/core": "workspace:^4.1.7",
    "@mastyf-ai/mcp-server": "workspace:^4.1.7"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^3.2.4",
    "@types/node": "^20.0.0"
  },
  "license": "MIT"
}
