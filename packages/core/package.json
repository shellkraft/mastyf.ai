{
  "name": "@mcp-guardian/core",
  "version": "3.2.4",
  "description": "Detection engine: regex + schema + semantic analysis for MCP tool definitions",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./transports/stdio": {
      "import": "./dist/transports/stdio.js",
      "types": "./dist/transports/stdio.d.ts"
    },
    "./transports/http": {
      "import": "./dist/transports/http.js",
      "types": "./dist/transports/http.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ioredis": "^5.10.1",
    "lru-cache": "^11.3.6"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^3.2.4",
    "@types/node": "^20.0.0"
  },
  "keywords": [
    "mcp",
    "security",
    "prompt-injection",
    "detection"
  ],
  "license": "MIT"
}
