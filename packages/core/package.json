{
  "name": "@mastyf-ai/core",
  "version": "4.1.7",
  "description": "Detection engine: regex + schema + semantic analysis for MCP tool definitions",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./transports/stdio": {
      "import": "./dist/transports/stdio.js",
      "types": "./dist/transports/stdio.d.ts"
    },
    "./transports/http": {
      "import": "./dist/transports/http.js",
      "types": "./dist/transports/http.d.ts"
    },
    "./transports/http-fetch-client": {
      "import": "./dist/transports/http-fetch-client.js",
      "types": "./dist/transports/http-fetch-client.d.ts"
    },
    "./semantic-duration-hook": {
      "import": "./dist/semantic-duration-hook.js",
      "types": "./dist/semantic-duration-hook.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && node scripts/verify-core-dist.mjs",
    "test": "vitest run",
    "test:regex-safety": "vitest run tests/argument-regex-safety.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ioredis": "^5.10.1",
    "lru-cache": "^11.3.6",
    "undici": "^7.28.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "safe-regex": "^2.1.1",
    "typescript": "^5.4.0",
    "vitest": "^3.2.4"
  },
  "keywords": [
    "mcp",
    "security",
    "prompt-injection",
    "detection"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ]
}
