# mastyf.ai Cloud — local environment
# Copy to apps/cloud/.env.local and fill in secrets.
# OAuth setup: apps/cloud/docs/OAUTH_CLOUD_SETUP.md

# App — use localhost in dev so badge links stay on your machine
AUTH_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_CLOUD_URL=http://localhost:3001
AUTH_SECRET=generate-with-openssl-rand-base64-32

# OAuth — GitHub/Google for production-like sign-in (see docs/OAUTH_CLOUD_SETUP.md)
# Quick local sign-in without OAuth: AUTH_DEV_LOGIN=true
AUTH_DEV_LOGIN=true
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Database (Postgres — required for sign-in / accounts)
DATABASE_URL=postgresql://mastyf_ai_cloud@localhost:5432/mastyf_ai_cloud

# Service key for GET /api/v1/reports/performance (Base44 Superagent, ops)
# Generate: openssl rand -base64 32
MASTYF_REPORTS_API_KEY=

# Shared secret for Mastyf AI cloud-exchange session JWT (set same on Mastyf AI as MASTYF_AI_CLOUD_JWT_SECRET)
LICENSE_JWT_SECRET=generate-with-openssl-rand-base64-32

# Webhook auto-registration (production, optional legacy billing)
# LEMONSQUEEZY_WEBHOOK_SECRET=
# LEMONSQUEEZY_STORE_ID=
