# MCP Mastyff AI SOC Dashboard — environment variables
#
# Copy to .env.local and adjust for your setup.

# ── API Backend ──────────────────────────────────────────────────────────────
#
# Port the Mastyff AI proxy/dashboard API listens on (default: 4000 for dashboard:proxy).
# next.config.ts uses this at startup to configure the /api/* rewrite in `dashboard:dev`.
SOC_API_PORT=4000

# Override to point the dashboard at a different host/port for the API.
# Leave commented out when using http://localhost:4000/ (static export from dashboard:build).
# NEXT_PUBLIC_MASTYFF_AI_API=http://localhost:4000

# ── Multi-tenant / Auth ───────────────────────────────────────────────────────
# MASTYFF_AI_TENANT_ID=default
