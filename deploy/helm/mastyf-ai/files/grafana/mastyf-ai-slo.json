{
  "title": "MCP Mastyf AI SLO",
  "panels": [
    {
      "title": "Proxy latency p99 (ms)",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(mastyf_ai_proxy_latency_ms_bucket[5m])) by (le))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      }
    },
    {
      "title": "SLO: % requests under 200ms p99 window",
      "targets": [
        {
          "expr": "100 * (1 - (histogram_quantile(0.99, sum(rate(mastyf_ai_proxy_latency_ms_bucket[5m])) by (le)) > 200))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 95 },
              { "color": "green", "value": 99 }
            ]
          }
        }
      }
    },
    {
      "title": "Semantic audit skipped (rate)",
      "targets": [
        {
          "expr": "sum(rate(mastyf_ai_semantic_audit_skipped_total[5m])) by (reason, tenant_id)"
        }
      ]
    },
    {
      "title": "Attacks blocked",
      "targets": [
        {
          "expr": "sum(rate(mastyf_ai_attacks_blocked_total[5m])) by (rule)"
        }
      ]
    },
    {
      "title": "Cost spent USD (by tenant)",
      "targets": [
        {
          "expr": "sum by (tenant_id) (increase(mastyf_ai_cost_spent_usd[1h]))"
        }
      ]
    }
  ],
  "schemaVersion": 39
}
